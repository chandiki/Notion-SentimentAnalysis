        "### **Text Reconstruction**"
      ],
      "metadata": {
        "id": "Q7wTXxajFhUa"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Reconstruct tokens into cleaned text\n",
        "df['final_text'] = df['final_tokens'].apply(lambda tokens: \" \".join(tokens))\n",
        "\n",
        "# Check empty results after reconstruction\n",
        "empty_count = df['final_text'].apply(lambda x: len(x.strip()) == 0).sum()\n",
        "\n",
        "print(f\"Empty texts after reconstruction: {empty_count:,}\")\n",
        "\n",
        "# Remove empty rows\n",
        "df = df[df['final_text'].str.len() > 0]\n",
        "\n",
        "print(f\"Remaining dataset size: {len(df):,} rows\")"
      ],
      "metadata": {
